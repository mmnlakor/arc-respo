# ─────────────────────────────────────────────
# Arc Testnet
# ─────────────────────────────────────────────
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# Your deployer wallet — NEVER commit the real key
# Add it in Railway → Variables tab
PRIVATE_KEY=0xyour_private_key_here

# ─────────────────────────────────────────────
# Arc Testnet official addresses
# ─────────────────────────────────────────────
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# ─────────────────────────────────────────────
# Populated automatically after deploy.js runs
# Copy these from Railway logs into Variables
# ─────────────────────────────────────────────
ORACLE_ADDRESS=
FACTORY_ADDRESS=

# ─────────────────────────────────────────────
# Railway deploy control
# ─────────────────────────────────────────────
SKIP_DEPLOY=false

# ─────────────────────────────────────────────
# Protocol config
# ─────────────────────────────────────────────
# Fee in basis points — 200 = 2%
PROTOCOL_FEE_BPS=200

# Oracle price freshness window in seconds — 3600 = 1 hour
ORACLE_FRESHNESS_SECONDS=3600
